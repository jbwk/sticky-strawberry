{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sticky-strawberry",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('/Users/joe.bahar/Documents/Claude/sticky-strawberry',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(f);const t={'html':'text/html','js':'application/javascript','json':'application/json','mp3':'audio/mpeg','png':'image/png'}[ext.slice(1)]||'text/plain';res.writeHead(200,{'Content-Type':t});res.end(d);}});}).listen(process.env.PORT||3456,()=>console.log('ok'))"],
      "port": 3456,
      "autoPort": true
    }
  ]
}
